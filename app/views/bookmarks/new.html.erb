<div class="container py-5">
  <h1>Add a movie to <%= @list.name %></h1>

  <%= simple_form_for [@list, @bookmark] do |f| %>
    <%= f.association :movie %>
    <%= f.input :comment %>
    <%= f.submit "Add movie", class: "btn btn-primary" %>
  <% end %>

  <div class="mt-3">
    <%= link_to "Back to list", list_path(@list) %>
  </div>
</div>
