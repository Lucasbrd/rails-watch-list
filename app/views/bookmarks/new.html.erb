<div class="container py-5">
  <div class="form-card">
    <h1>Ajouter un film à <%= @list.name %></h1>

    <%= simple_form_for [@list, @bookmark] do |f| %>
      <%= f.association :movie, label: "Film" %>
      <%= f.input :comment, label: "Commentaire" %>
      <%= f.submit "Ajouter le film", class: "btn btn-primary" %>
    <% end %>

    <div class="mt-3">
      <%= link_to "Retour à la liste", list_path(@list) %>
    </div>
  </div>
</div>
