<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-2"><%= @list.name %></h1>
      <p class="text-muted mb-0">
        Retrouvez tous les films ajoutés à cette liste.
      </p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "Retour aux listes", lists_path, class: "btn btn-outline-secondary" %>
      <%= link_to "Ajouter un film", new_list_bookmark_path(@list), class: "btn btn-primary" %>
    </div>
  </div>

  <% if @list.bookmarks.any? %>
    <div class="row">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="col-12 mb-4">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              <div class="d-flex gap-4">
                <%= image_tag bookmark.movie.poster_url,
                  alt: bookmark.movie.title,
                  class: "rounded shadow-sm",
                  style: "width: 160px; height: 240px; object-fit: cover; flex-shrink: 0;" %>

                <div class="d-flex flex-column justify-content-between w-100">
                  <div>
                    <div class="d-flex justify-content-between align-items-start">
                      <h2 class="h4 mb-2"><%= bookmark.movie.title %></h2>

                      <span class="badge bg-warning text-dark">
                        ⭐ <%= bookmark.movie.rating %>
                      </span>
                    </div>

                    <p class="text-muted mb-3">
                      <%= bookmark.movie.overview %>
                    </p>

                    <div class="bg-light rounded p-3">
                      <p class="mb-1 fw-bold">Commentaire</p>
                      <p class="mb-0"><%= bookmark.comment %></p>
                    </div>
                  </div>

                  <div class="text-end mt-3">
                    <%= link_to "Supprimer",
                      bookmark_path(bookmark),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce film de la liste ?"
                      },
                      class: "btn btn-outline-danger btn-sm" %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <h2 class="h4 mb-3">Aucun film dans cette liste pour le moment</h2>
        <p class="text-muted mb-4">
          Ajoutez votre premier film pour commencer votre watch list.
        </p>

        <%= link_to "Ajouter un film", new_list_bookmark_path(@list), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
