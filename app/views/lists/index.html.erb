<div class="banner">
  <div class="container">
    <div class="banner-content">
      <span class="eyebrow">Watch List</span>
      <h1>La Cinémathèque privée</h1>
      <p>Organise tes films préférés dans des collections élégantes, par ambiance, genre ou envie du moment.</p>

      <%= link_to "Créer une nouvelle collection",
                  new_list_path,
                  class: "btn btn-primary btn-lg" %>
    </div>
  </div>
</div>

<div class="container py-5">
  <div class="section-heading">
    <div>
      <span class="eyebrow-dark">Collections</span>
      <h2>Mes listes de films</h2>
      <p>Choisis une collection et retrouve les films que tu as sélectionnés.</p>
    </div>
  </div>

  <% if @lists.any? %>
    <div class="row">
      <% @lists.each do |list| %>
        <% category_class = list.name.parameterize %>

        <div class="col-12 col-sm-6 col-lg-4 mb-4">
          <%= link_to list_path(list), class: "text-decoration-none" do %>
            <div class="list-card <%= category_class %>">
              <div class="list-card-overlay">
                <span class="list-tag">Collection</span>
                <h3><%= list.name %></h3>
                <p><%= pluralize(list.movies.count, "film") %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <span class="eyebrow-dark">Première collection</span>
      <h2>Aucune liste pour le moment</h2>
      <p>Crée ta première collection pour commencer à organiser tes films.</p>

      <%= link_to "Créer une liste",
                  new_list_path,
                  class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
